{
  "name": "assigned",
  "displayName": "Assigned",
  "description": "Shows your assigned GitLab MRs and lets you review them in one click with Copilot",
  "version": "1.0.0",
  "publisher": "johnny",
  "repository": { "type": "git", "url": "https://github.com/johnnyoy/assigned" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "assigned",
          "title": "Assigned Reviews",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "assigned": [
        {
          "id": "assigned.mrList",
          "name": "Assigned MRs"
        }
      ]
    },
    "commands": [
      {
        "command": "assigned.configure",
        "title": "Assigned: Configure"
      },
      {
        "command": "assigned.reviewMR",
        "title": "Review MR",
        "icon": "$(play)"
      },
      {
        "command": "assigned.refresh",
        "title": "Assigned: Refresh Now",
        "icon": "$(refresh)"
      },
      {
        "command": "assigned.openMR",
        "title": "Open on GitLab",
        "icon": "$(link-external)"
      },
      {
        "command": "assigned.signOut",
        "title": "Assigned: Sign Out",
        "icon": "$(sign-out)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "assigned.mrList",
        "contents": "No GitLab token configured.\n[Configure](command:assigned.configure)",
        "when": "!assigned.configured"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "assigned.refresh",
          "when": "view == assigned.mrList && assigned.configured",
          "group": "navigation"
        },
        {
          "command": "assigned.signOut",
          "when": "view == assigned.mrList && assigned.configured",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "assigned.openMR",
          "when": "view == assigned.mrList && viewItem == mr",
          "group": "inline@1"
        },
        {
          "command": "assigned.reviewMR",
          "when": "view == assigned.mrList && viewItem == mr",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Assigned",
      "properties": {
        "assigned.pollIntervalMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "How often to poll GitLab for assigned MRs (in minutes)"
        },
        "assigned.gitlabUrl": {
          "type": "string",
          "default": "https://gitlab.com",
          "pattern": "^https://",
          "patternErrorMessage": "GitLab URL must start with https://",
          "description": "Your GitLab instance URL (must be HTTPS)"
        },
        "assigned.maxDiffFiles": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of changed files to open as diffs during a review"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
